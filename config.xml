<?xml version='1.0' encoding='utf-8'?>
<widget id="com.birrgo.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Birr Go</name>
    <description>
        My Custom GitHub Pages Web App
    </description>
    <author email="dev@birrgo.online" href="https://test.birrgo.online">
        Birrgo Team
    </author>

    <!-- Point the app launch source directly to your domain -->
    <content src="https://test.birrgo.online" />

    <!-- Default App Launcher Icon -->
    <icon src="icon.png" />

    <platform name="android">
        <!-- Main launcher icon mapping -->
        <icon src="icon.png" />

        <!-- Generic / Firebase Notification status bar icon -->
        <resource-file src="badge-icon.png" target="app/src/main/res/drawable/ic_stat_notification.png" />

        <!-- OneSignal Native SDK default status bar icon -->
        <resource-file src="badge-icon.png" target="app/src/main/res/drawable/ic_stat_onesignal_default.png" />

        <!-- Android Manifest Configuration for Firebase & OneSignal Defaults -->
        <config-file parent="/manifest/application" target="AndroidManifest.xml">
            <!-- Default Firebase Notification Icon -->
            <meta-data 
                android:name="com.google.firebase.messaging.default_notification_icon" 
                android:resource="@drawable/ic_stat_notification" />

            <!-- Default OneSignal Notification Icon -->
            <meta-data 
                android:name="com.onesignal.NotificationIcon.Default" 
                android:value="ic_stat_onesignal_default" />
        </config-file>
    </platform>

    <!-- Security Rules: Allow your app to load external resources and navigate -->
    <access origin="https://test.birrgo.online" />
    <access origin="*" />
    
    <allow-navigation href="https://test.birrgo.online/*" />
    <allow-navigation href="*://*.test.birrgo.online/*" />

    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    
    <preference name="KeepRunning" value="true" />
</widget>
